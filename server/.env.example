# === PayPal API (sandbox par défaut) ===
# 1. Va sur https://developer.paypal.com/dashboard/applications
# 2. Crée une app REST API si ce n'est pas déjà fait
# 3. Note le Client ID (celui-ci est déjà dans panier.js)
# 4. Copie le Secret (le mettre ci-dessous)

PAYPAL_CLIENT_ID=AY9HXafcPHStF8HwHiwdJ1OyRDSC739naTxvTnA_PbjIZXa4hF2Acb3735u7zgST8zok7jCcaMBkKtQN
PAYPAL_CLIENT_SECRET=metton_client_secret_ici

# JWT secret (changez ceci en chaîne aléatoire longue)
JWT_SECRET=change-this-to-a-long-random-string

# Port du serveur
PORT=3000

# URL du site (pour CORS)
CLIENT_ORIGIN=https://tachihant.github.io

# Mode PayPal : sandbox ou live
# sandbox = tests (utilise des comptes factices)
# live = production (vrais paiements)
PAYPAL_MODE=sandbox
